{
  "name": "dafman",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "electrobun dev --watch",
    "predev": "bun run prep:dist",
    "dev:hmr": "bun run prep:dist && concurrently \"bun run hmr\" \"bun run dev\"",
    "prep:dist": "bun run tools/prep-dist.ts",
    "hmr": "vite --port 5173",
    "start": "vite build && electrobun dev",
    "build": "vite build && electrobun build",
    "build:canary": "vite build && electrobun build --env=canary",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "smoke": "vite build && playwright test --config=e2e/playwright.config.ts",
    "smoke:run": "playwright test --config=e2e/playwright.config.ts",
    "e2e": "vite build && playwright test --config=e2e/full/playwright.config.ts",
    "e2e:run": "playwright test --config=e2e/full/playwright.config.ts",
    "lint": "vue-tsc --noEmit",
    "check": "bun run lint && bun run test && bun run build && bun run smoke:run"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@lexical/code": "0.38.1",
    "@lexical/link": "0.38.1",
    "@lexical/list": "0.38.1",
    "@lexical/markdown": "0.38.1",
    "@lexical/rich-text": "0.38.1",
    "@lexical/utils": "0.38.1",
    "@primeuix/themes": "^2.0.3",
    "codemirror": "^6.0.2",
    "copilot-sdk-supercharged": "^2.1.2",
    "dockview-vue": "^6.3.0",
    "dompurify": "^3.4.5",
    "electrobun": "1.18.1",
    "katex": "^0.16.47",
    "lexical": "0.38.1",
    "lexical-vue": "^0.14.1",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.13",
    "vue-command-palette": "^0.2.3"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/vue": "^8.1.0",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/prismjs": "^1.26.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.5.13",
    "concurrently": "^9.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
