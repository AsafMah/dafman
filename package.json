{
  "name": "dafman",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "electrobun dev --watch",
    "predev": "bun run prep:dist",
    "dev:hmr": "bun run prep:dist && concurrently \"bun run hmr\" \"bun run dev\"",
    "prep:dist": "bun run tools/prep-dist.ts",
    "hmr": "vite --port 5173",
    "start": "vite build && electrobun dev",
    "build": "vite build && electrobun build",
    "build:canary": "vite build && electrobun build --env=canary",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "smoke": "vite build && playwright test --config=e2e/playwright.config.ts",
    "smoke:run": "playwright test --config=e2e/playwright.config.ts",
    "e2e": "vite build && playwright test --config=e2e/full/playwright.config.ts",
    "e2e:run": "playwright test --config=e2e/full/playwright.config.ts",
    "lint": "vue-tsc --noEmit",
    "lint:bun": "bun run tools/check-bun-entry.ts",
    "lint:eslint": "eslint --no-error-on-unmatched-pattern 'src/**/*.{ts,vue}' 'src-bun/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,vue}' 'src-bun/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,vue}' 'src-bun/**/*.ts'",
    "check": "bun run lint && bun run lint:bun && bun run test && bun run build && bun run smoke:run"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@github/copilot": "^1.0.52",
    "@lexical/code": "0.44.0",
    "@lexical/link": "0.44.0",
    "@lexical/list": "0.44.0",
    "@lexical/markdown": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/selection": "^0.44.0",
    "@primeuix/themes": "^2.0.3",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dockview-core": "6.4.0",
    "dockview-vue": "6.4.0",
    "dompurify": "^3.4.5",
    "electrobun": "1.18.1",
    "katex": "^0.17.0",
    "lexical": "0.44.0",
    "lexical-vue": "^0.14.1",
    "markdown-it": "^14.1.1",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "prismjs": "^1.30.0",
    "strip-ansi": "^7.2.0",
    "vue": "3.5.34",
    "vue-command-palette": "^0.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "20.9.0",
