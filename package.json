{
  "name": "dafman",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "electrobun dev --watch",
    "predev": "bun run prep:dist",
    "dev:hmr": "bun run prep:dist && concurrently \"bun run hmr\" \"bun run dev\"",
    "prep:dist": "bun run tools/prep-dist.ts",
    "hmr": "vite --port 5173",
    "start": "vite build && electrobun dev",
    "build": "vite build && electrobun build",
    "build:canary": "vite build && electrobun build --env=canary",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "vue-tsc --noEmit",
    "check": "bun run lint && bun run test && bun run build"
  },
  "dependencies": {
    "@lexical/code": "0.38.1",
    "@lexical/link": "0.38.1",
    "@lexical/list": "0.38.1",
    "@lexical/markdown": "0.38.1",
    "@lexical/rich-text": "0.38.1",
    "@lexical/utils": "0.38.1",
    "@primeuix/themes": "^2.0.3",
    "copilot-sdk-supercharged": "^2.1.2",
    "dockview-vue": "^6.3.0",
    "electrobun": "1.18.1",
    "lexical": "0.38.1",
    "lexical-vue": "^0.14.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.0",
    "@testing-library/vue": "^8.1.0",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.5.13",
    "concurrently": "^9.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
