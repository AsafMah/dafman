    "globals": "^17.6.0",
    "gts": "^7.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "6.4.2",
    "vue-tsc": "2.2.12"
  },
  "overrides": {
