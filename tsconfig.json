{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Path aliases. TS 6+ no longer requires baseUrl; paths are
     * resolved relative to the tsconfig directory. */
    "paths": {
      "@/*": ["./src/*"]
    },
    /* TS 6 defaults `types` to `[]` (was: enumerate all of @types/*).
     * Renderer test files import from `bun:test`, so we need bun
     * types explicitly. This doesn't leak Bun globals into renderer
     * production code — tsconfig.bun.json is the canonical
     * typecheck for backend code. */
    "types": ["bun"],

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
  "references": [{ "path": "./tsconfig.node.json" }, { "path": "./tsconfig.bun.json" }]
}
