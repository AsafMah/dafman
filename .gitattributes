# Default: treat all files as text and normalize to LF on checkout + commit.
# Matches the repo's prettier config (`endOfLine: "lf"`) and dodges the
# `core.autocrlf=true` checkout-converts-to-CRLF trap on Windows.
* text=auto eol=lf

# Lockfiles must not be touched by line-ending normalization — bun's
# install consistency check is sensitive to byte-exact content. Mark
# binary so git ships the bytes through unchanged.
bun.lock binary
package-lock.json binary

# Binary types (no normalization).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
